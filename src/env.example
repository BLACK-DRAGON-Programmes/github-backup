# GitHub Backup Script — Environment Configuration Template
#
# Copy this file to .env in the SAME DIRECTORY as backup.exe and fill in
# your values. The executable automatically finds .env in its own directory.
# Do NOT place your real token in this file — this template stays in version
# control. The actual .env file is gitignored and never committed.
#
# On deployment: copy env.example to .env and replace placeholder values.
#
# This file contains ALL runtime-configurable values. The script reads this file
# fresh on every execution cycle, so changes take effect on the next cycle without
# recompilation. Values that cannot be changed at runtime (HTTP status codes, API
# URLs, buffer sizes, etc.) are compile-time constants defined in constants.h.


# === Authentication and Target ===

# OPTION A (recommended): Single URL containing both token and owner.
#
# The base URL containing the GitHub personal access token and the target
# account/organization path. The script parses this single string to extract
# both the authentication token and the target owner.
#
# Format: https://<TOKEN>@github.com/<OWNER>/
#
# - <TOKEN>: A GitHub personal access token with 'repo' scope. Embed the token
#   in the URL authority portion (before @github.com).
# - <OWNER>: The GitHub username or organization name whose repositories will
#   be backed up. This is the path segment after github.com/.
# - The trailing slash is required.
#
# Token rotation: To update an expired or compromised token, edit this value
# and replace the old token portion. No recompilation needed.
GITHUB_BASE_URL=https://<YOUR_PERSONAL_ACCESS_TOKEN>@github.com/<OWNER>/

# OPTION B (alternative): Separate token and owner fields.
# Use these when you prefer to keep the token and owner as distinct values.
# When GITHUB_TOKEN is present, it takes precedence over any token embedded
# in GITHUB_BASE_URL. GITHUB_OWNER is used when GITHUB_BASE_URL is absent.
#
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_OWNER=<OWNER>


# === Repository List ===

# Comma-separated list of repository names to back up. Only repositories
# listed here are downloaded — the script does NOT auto-discover repos.
#
# - Names must match the repository slug exactly (as they appear in the URL).
# - Whitespace around commas is trimmed by the parser.
# - Lines starting with # are ignored (comments).
# - Empty values are ignored.
#
# To add or remove a repository, edit this list and save. Changes take effect
# on the next hourly cycle — no restart needed.
REPOS=<repo-one>,<repo-two>,<repo-three>


# === Deployment Directory ===

# The root directory where backup.exe runs and where all output files
# are stored: zip archives, the .env file itself, and the log file.
# The script constructs the full paths to .env and backup.log by appending
# filenames to this directory path at runtime.
#
# Format: D:\BACKUP\
# - The trailing backslash is required.
# - Use double backslashes only if your environment requires escaping.
#
# Change this to deploy the script to a different directory without
# recompiling.
BACKUP_DIR=D:\BACKUP\


# === Timing ===

# How many seconds the script sleeps between consecutive backup cycles.
# After completing a cycle, the script sleeps for this duration, then
# checks internet connectivity and begins the next cycle.
#
# Default: 3600 (1 hour). Set to 1800 for 30-minute cycles, 7200 for
# 2-hour cycles, etc.
CYCLE_INTERVAL_SECONDS=3600


# === Network Timeouts ===

# Timeout in milliseconds for HTTP requests to the GitHub API. This
# applies to both repo metadata queries and zip archive downloads. If
# a request does not complete within this time, it is treated as a
# failure and the script continues with the next repo.
#
# Default: 30000 (30 seconds). Increase for slow connections or large
# repositories. Decrease for faster failure detection.
HTTP_TIMEOUT_MS=30000

# Timeout in milliseconds for the pre-cycle internet connectivity check.
# This is a lightweight probe that determines whether the network is
# available before attempting any API calls. If the check does not
# complete within this time, the cycle is skipped.
#
# Default: 5000 (5 seconds). Should be kept short to avoid delaying
# the cycle-skip decision when the network is genuinely unavailable.
CONNECTIVITY_CHECK_TIMEOUT_MS=5000


# === Log Rotation ===

# Maximum size of the log file (backup.log) in bytes before rotation
# occurs. When the log file exceeds this size, it is deleted and
# started fresh. The log is ephemeral, not an archive.
#
# Default: 1048576 (1 MiB). At ~2-3 KiB per backup cycle, this retains
# approximately 14-20 days of history. Set to 0 to disable rotation
# (the log will grow indefinitely — not recommended).
LOG_MAX_SIZE_BYTES=1048576
